#. Description of the plugin
#: minimal-map-net-locator-block.php
msgid "Gutenberg-first native map block and admin shell for WordPress."
msgstr ""
"Gutenberg-orientierter nativer Kartenblock und Admin-Oberfläche für "
"WordPress."

#. Author of the plugin
#: minimal-map-net-locator-block.php
msgid "Emilian Scheel"
msgstr "Emilian Scheel"

